<!DOCTYPE html>
<html>
<head>
    <title>My App</title>
</head>
<body>

<h1>Welcome</h1>

<!-- Get the email from the URL -->
<div id="result"></div>

<script>
    // Get the "column" value from the URL
    const urlParams = new URLSearchParams(window.location.search);
    const email = urlParams.get('column');
    
    // Show it on the page
    document.getElementById('result').innerHTML = 
        "You searched for email: <b>" + email + "</b>";
</script>

</body>
</html>
